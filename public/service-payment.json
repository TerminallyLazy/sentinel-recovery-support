        "transactionHash"
      ],
      "erc20Tuple": [
        "chainId",
        "transactionHash",
        "logIndex"
      ],
      "uniqueAcrossQuotes": true,
      "reuseHandling": "do-not-credit; manual-review"
    },
    "receiptStates": {
      "pending": {
        "terminal": false,
        "reasonCodes": [
          "transaction-not-observed",
          "confirmation-depth-not-met",
          "provider-timeout"
        ]
      },
      "verified": {
        "terminal": true,
        "reasonCodes": [
          "exact-quote-tuple-confirmed"
        ]
      },
      "rejected": {
