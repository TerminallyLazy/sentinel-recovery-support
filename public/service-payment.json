      "manual-review": {
        "terminal": false,
        "reasonCodes": [
          "duplicate",
          "late",
          "partial",
          "overpayment",
          "reorg-or-conflicting-evidence"
        ]
      }
    },
    "exceptionHandling": {
      "duplicate": "do-not-credit-twice; manual-review",
      "late": "do-not-start-work; manual-review",
      "partial": "do-not-start-work; manual-review",
      "overpayment": "do-not-expand-entitlement; manual-review"
    }
