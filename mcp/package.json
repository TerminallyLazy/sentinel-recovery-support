{
  "name": "sentinel-recovery-mcp",
  "version": "0.3.0",
  "description": "Deterministic agent-payment and x402 PaymentRequired preflights plus read-only Sentinel Recovery service resources.",
  "type": "module",
  "bin": {
    "sentinel-recovery-mcp": "server.mjs"
  },
  "files": [
    "README.md",
    "preflight.mjs",
    "server.mjs",
    "x402-payment-required.mjs"
  ],
  "scripts": {
    "start": "node server.mjs",
    "test": "node --test server.test.mjs",
    "pack:check": "npm pack --dry-run",
    "mcpb:validate": "npx --yes @anthropic-ai/mcpb@2.1.2 validate manifest.json"
  },
  "engines": {
    "node": ">=20"
  },
  "mcpName": "io.github.terminallylazy/sentinel-recovery-services",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TerminallyLazy/sentinel-recovery-support.git",
    "directory": "mcp"
  },
  "homepage": "https://terminallylazy.github.io/sentinel-recovery-support/",
  "bugs": {
    "url": "https://github.com/TerminallyLazy/sentinel-recovery-support/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "ethereum",
    "x402",
    "eip-3009",
    "payment-boundaries"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "zod": "4.4.3"
  }
}
