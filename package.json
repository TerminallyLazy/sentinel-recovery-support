{
  "name": "sentinel-recovery-support",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "predev": "node scripts/clean-pages.mjs",
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "prebuild": "node scripts/clean-pages.mjs",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "export:pages": "npm run build && node scripts/export-pages.mjs",
    "preview:pages": "npm run export:pages && node scripts/preview-pages.mjs",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:revenue": "node --test tests/service-quote.test.mjs tests/service-receipt.test.mjs tests/revenue-operations.test.mjs",
    "quote:create": "node scripts/create-service-quote.mjs",
    "quote:prepare": "node scripts/prepare-service-quote.mjs",
    "receipt:verify": "node scripts/verify-service-receipt.mjs",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next --ignore-pattern pages"
  },
  "dependencies": {
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "8.0.16",
    "wrangler": "4.102.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.16"
    }
  },
  "type": "module"
}
